---
import Layout from "../layouts/Layout.astro";

const boardMembers = [
    {
        name: "Derk Weijers",
        role: "Chair",
        bio: "Derk is a software developer and Python enthusiast with over 10 years of experience in the tech industry. He is an active member of various communities, contributing to various open-source projects and organizing local meetups. Attending EuroPython is always one his personal highlights of the year.",
        initials: "DW",
    },
    {
        name: "Henk-Jan van Hasselaar",
        role: "Secretary",
        bio: "Henk-Jan van Hasselaar is a Staff Software Engineer at Alliander and Secretary of the Board of the PyNetherlands community foundation. He has been working with Python since version 2.6, back when type hints weren't a thing and dependency management discussions required significantly less therapy. In his day-to-day work, he helps teams build more resilient software by improving security, software quality, and compliance practices across the organization.",
        initials: "HH",
    },
    {
        name: "Derviş van Leersum",
        role: "Treasurer",
        bio: "From calculating load-bearing structures to load-bearing Python scripts, Derviş made the leap from structural engineering to software development nearly a decade ago and never looked back. These days he's a software engineer at Sopra Steria, working on projects for TenneT that contribute to a stable and smarter energy grid. If you ask him, helping build the infrastructure for the energy transition is a pretty exciting place to write Python for a living.",
        initials: "DL",
    },
    {
        name: "Aristeidis Nivorlis",
        role: "Board Member",
        bio: "",
        initials: "AN",
    },
    {
        name: "Ravi Selker",
        role: "Board Member",
        bio: "",
        initials: "RS",
    },
    {
        name: "Esther Roghair",
        role: "Board Member",
        bio: "",
        initials: "ER",
    },
];
---

<Layout title="Board" description="Meet the board.">
    <div class="container page">
        <header class="page-header">
            <h1>Board</h1>
            <p>
                PyNetherlands is governed by the board, responsible for the
                strategic direction, finances, and day-to-day operations of the
                foundation.
            </p>
        </header>

        <div class="board-grid">
            {
                boardMembers.map((member) => (
                    <div class="member-card">
                        <div class="member-avatar">{member.initials}</div>
                        <div class="member-info">
                            <h2>{member.name}</h2>
                            <span class="member-role">{member.role}</span>
                            <p>{member.bio}</p>
                        </div>
                    </div>
                ))
            }
        </div>

        <aside class="board-note">
            <p>
                The foundation's board serves in a voluntary capacity. For
                inquiries, please reach out via <a href="mailto:info@pynl.org"
                    >info@pynl.org</a
                >.
            </p>
        </aside>
    </div>
</Layout>

<style>
    .board-grid {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .member-card {
        display: flex;
        gap: 1.75rem;
        align-items: flex-start;
        background: var(--bg-subtle);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.75rem;
    }

    .member-avatar {
        flex-shrink: 0;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--blue);
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        letter-spacing: 0.05em;
    }

    .member-info h2 {
        font-size: 1.1rem;
        margin: 0 0 0.25rem;
    }

    .member-role {
        display: inline-block;
        background: #e8f1f9;
        color: var(--blue);
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
        margin-bottom: 0.75rem;
    }

    .member-info p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.65;
        margin: 0;
    }

    .board-note {
        background: #fffbea;
        border: 1px solid #f0e68c;
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .board-note p {
        margin: 0;
    }

    @media (max-width: 500px) {
        .member-card {
            flex-direction: column;
        }
    }
</style>
